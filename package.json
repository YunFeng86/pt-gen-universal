{
  "name": "pt-gen-universal",
  "version": "2.0.0",
  "description": "PT-Gen on server and serverless platforms",
  "packageManager": "pnpm@9.15.9",
  "main": "src/adapters/node.ts",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/adapters/node.ts",
    "dev:cf": "wrangler dev",
    "dev:bun": "bun --hot src/adapters/bun.ts",
    "dev:node": "tsx watch src/adapters/node.ts",
    "start": "pnpm run start:node",
    "build:cf": "wrangler deploy",
    "build:vercel": "pnpm exec tsc --noEmit",
    "build:netlify": "pnpm exec tsc --noEmit",
    "build:edgeone": "pnpm exec tsc --noEmit",
    "start:bun": "bun src/adapters/bun.ts",
    "start:node": "tsx src/adapters/node.ts",
    "build": "wrangler build",
    "preview": "wrangler preview",
    "publish": "wrangler publish",
    "deploy": "wrangler deploy",
    "format": "prettier --write \"**/*.{ts,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md}\"",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "check": "pnpm exec tsc --noEmit && pnpm run test:run && pnpm run build"
  },
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=9 <10"
  },
  "author": "YunFeng <YunFengZero@outlook.com>",
  "forkedFrom": "github.com/Rhilip/pt-gen-cfworker",
  "contributors": [
    "Rhilip <rhilipruan@gmail.com>"
  ],
  "license": "MIT",
  "dependencies": {
    "@netlify/blobs": "^10.7.4",
    "@hono/node-server": "^1.13.7",
    "@upstash/redis": "^1.37.0",
    "cheerio": "^1.1.2",
    "hono": "^4.11.7",
    "html2bbcode": "^1.2.6",
    "redis": "^5.11.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.9",
    "prettier": "^3.4.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.17",
    "wrangler": "^4.59.1"
  },
  "overrides": {
    "entities": "^7.0.0",
    "undici": "^7.18.2"
  }
}
