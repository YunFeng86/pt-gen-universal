# PT-Gen 环境变量配置示例
# 复制此文件为 .env 并填入你的配置（主要用于 Node.js / Railway / Zeabur 本地或预发环境）
# Cloudflare / EdgeOne 的 KV 绑定不通过 .env 配置，而是通过平台绑定注入。

# =========================
# 通用应用配置
# =========================

# API 访问密钥（可选）
# 设置后需在请求中添加 ?apikey={APIKEY}
APIKEY=

# 禁用搜索功能（可选）
# 设置为任意非空值时禁用搜索功能，默认：不禁用
DISABLE_SEARCH=

# 豆瓣 Cookie（可选）
# 用于访问登录可见资源
DOUBAN_COOKIE=

# indienova Cookie（可选）
# 参考：https://github.com/Rhilip/pt-gen-cfworker/issues/15
INDIENOVA_COOKIE=

# TMDB API 密钥（可选，若需要TMDB功能则必填）
# 用于访问 TMDB 资源，获取地址：https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# 请求超时（毫秒，可选）
REQUEST_TIMEOUT_MS=

# 服务器端口（仅 Node.js / Bun / Railway / Zeabur）
# 默认：3000
PORT=

# 缓存过期时间（秒）
# 默认：172800（2天）
# 示例：86400（1天）、604800（7天）、0（禁用缓存）
CACHE_TTL=

# 缓存存储策略（可选）
# auto | memory | cloudflare-kv | vercel-redis | netlify-blobs | edgeone-kv | redis
# 默认：auto
STORAGE_PROVIDER=

# 缓存逻辑存储名（Netlify Blobs 等会使用）
# 默认：pt-gen-cache
CACHE_STORE_NAME=

# 请求级限流模式（可选）
# off | best-effort
# 默认：off；off 会强制关闭请求级限流，即使设置了 RATE_LIMIT_PER_MINUTE 也不会启用
RATE_LIMIT_MODE=

# 请求级限流阈值（每分钟请求数）
# 仅在 RATE_LIMIT_MODE=best-effort 时生效；其余模式下会被忽略
RATE_LIMIT_PER_MINUTE=

# Node/Bun/Node fallback 内存缓存：最大条目数（可选）
# 默认：5000（KV 不受影响）
# 设置为 0 表示不限制（不推荐，可能导致长期运行内存增长）
CACHE_MAX_ENTRIES=

# Node/Bun/Node fallback 内存缓存：过期条目清理间隔（毫秒，可选）
# 默认：30000
CACHE_SWEEP_INTERVAL_MS=

# =========================
# 抓取与代理配置
# =========================

# 可选：抓取代理/中转（适用于网络受限环境）
# 说明：这是"URL 中转/Relay"形式的代理，不是传统的 HTTP CONNECT 代理。
# 支持两种写法：
# 1) 前缀模式：PROXY_URL=https://r.jina.ai/
#    最终请求：https://r.jina.ai/https://example.com/...
# 2) 模板模式：
#    - PROXY_URL=https://proxy.example/fetch?url={urlEncoded}
#    - PROXY_URL=https://proxy.example/fetch/{url}
PROXY_URL=

# 可选：是否允许在使用 PROXY_URL 时转发敏感请求头（Cookie/Authorization）
# 默认：false（更安全；避免把 Cookie 泄露给第三方中转服务）
# 仅在你完全信任中转服务/自建中转时才开启
PROXY_ALLOW_SENSITIVE_HEADERS=

# 自定义抓取头/超时（可选）
DOUBAN_USER_AGENT=
DOUBAN_ACCEPT_LANGUAGE=
DOUBAN_TIMEOUT_MS=
DOUBAN_WARMUP_TIMEOUT_MS=
IMDB_USER_AGENT=
IMDB_TIMEOUT_MS=
TMDB_USER_AGENT=
TMDB_TIMEOUT_MS=

# =========================
# 平台存储变量
# =========================

# Railway / Zeabur / 本地 Redis
REDIS_URL=

# Vercel Marketplace Redis / Upstash REST
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# 兼容部分 Vercel Marketplace/KV 场景的别名
KV_REST_API_URL=
KV_REST_API_TOKEN=
